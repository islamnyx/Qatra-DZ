# ─── Frontend (Vite) — copy to .env.local ───────────────────────────────

# REST API (default). Keep /api when using Vite proxy to localhost:3001
VITE_API_URL=/api

# Data source: "rest" (Node backend) | "firebase" (Firebase team)
VITE_DATA_PROVIDER=rest

# ─── Firebase (Firebase team only) ─────────────────────────────────────
# Create project: https://console.firebase.google.com
# Project settings → Your apps → Web app → copy config values

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: use Firebase Emulators locally
# VITE_FIREBASE_USE_EMULATORS=false
