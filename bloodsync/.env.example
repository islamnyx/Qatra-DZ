# BloodSync — copy to .env.local

# mock = in-browser hospital DB (default, no Firebase needed)
# firebase = live Firestore (requires VITE_FIREBASE_* below)
VITE_DATA_PROVIDER=mock

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=quatra-dz-bb7cc
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Must match donor app key for decrypting pre_screening
VITE_PRESCREENING_KEY=qatra-prescreen-demo-key-32chars!!
